# =====================================================================================
# 🔐 NEXTAUTH – GOOGLE LOGIN
# =====================================================================================

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# URL gốc của NextAuth (local)
NEXTAUTH_URL=http://localhost:3000

# Secret bắt buộc (generate với: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# =====================================================================================
# 🔒 DATA ENCRYPTION KEY (REQUIRED - CRITICAL FOR SECURITY)
# =====================================================================================

# REQUIRED: Encryption key for message content (minimum 32 characters)
# Generate with: openssl rand -base64 32
# WARNING: Without this key, the app will NOT start (security requirement)
DATA_ENCRYPTION_KEY=your_data_encryption_key_here_minimum_32_chars

# =====================================================================================
# 🛡️ WHITELIST – CHỈ ALLOW EMAIL BẠN MUỐN
# =====================================================================================

WHITELIST_EMAILS=your-email@example.com

# =====================================================================================
# 🤖 GEMINI API KEY (SERVER ONLY)
# =====================================================================================

GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================================================
# 🧠 DEEPSEEK API KEY (Direct API for V4 models)
# =====================================================================================

DEEPSEEK_API_KEY=your_deepseek_api_key_here

# =====================================================================================
# 🌐 NEXT.JS CONFIG
# =====================================================================================

NEXT_PUBLIC_APP_ENV=development

# =====================================================================================
# 🗄️ SUPABASE
# =====================================================================================

SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =====================================================================================
# 📦 REDIS (UPSTASH)
# =====================================================================================

UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# =====================================================================================
# 📎 ATTACHMENTS CONFIG
# =====================================================================================

ATTACHMENTS_CRON_SECRET=your_cron_secret_here
ATTACHMENTS_TTL_HOURS=36
ATTACHMENTS_BUCKET=vikini-attachments

# =====================================================================================
# 🔍 FEATURES
# =====================================================================================

WEB_SEARCH_ENABLED=true
URL_CONTEXT_ENABLED=1

# =====================================================================================
# 📎 ATTACHMENT LIMITS
# =====================================================================================

ATTACH_MAX_TEXT_BYTES=2097152
ATTACH_MAX_IMAGE_BYTES=10485760
ATTACH_MAX_FILES_PER_CONV=20
ATTACH_MAX_TOTAL_BYTES_PER_CONV=52428800
ATTACH_ANALYZE_MAX_CHARS=120000
ATTACH_CONTEXT_MAX_CHARS=150000
ATTACH_CONTEXT_MAX_IMAGES=5
ATTACH_CONTEXT_MAX_IMAGE_BYTES=4194304

